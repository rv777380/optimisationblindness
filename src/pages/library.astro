---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const essays = await getCollection('essays');
essays.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const dateFmt = (d: Date) =>
  d.toLocaleDateString('en-GB', { month: 'long', year: 'numeric' });
---

<BaseLayout
  title="Library"
  description="The working bibliographic record of the optimisation blindness research programme."
>
  <article class="prose">
    <h1>Library</h1>

    <p>The working bibliographic record of the optimisation blindness research programme. This page lists every concept, framework, mechanism, essay, and working paper developed on this site, with version, status, and suggested citation. Readers writing about any element of the work should find what they need here without browsing.</p>

    <hr />

    <section class="library-section">
      <h2>Concept</h2>
      <div class="library-entry">
        <p class="name">Optimisation Blindness</p>
        <p class="description">A general account of what AI optimisation systems cannot see by design. Developed across two structural moves (algorithmic curation and data extraction) expressed through four facets (herding, flattening, transactional extraction, ambient surveillance).</p>
        <p class="status">Version 1.0 · First published May 2026 · Status: conceptual essay, under continuing development on this site.</p>
        <p class="canonical">Canonical page: <a href="/concept">optimisationblindness.org/concept</a></p>
      </div>
    </section>

    <section class="library-section">
      <h2>Frameworks</h2>

      <div class="library-entry">
        <p class="name">RevEmo — Revenue per Emotional Moment</p>
        <p class="description">Property-level measurement framework quantifying the economic impact of emotional moments on revenue uplift, retention, and asset valuation in hospitality contexts.</p>
        <p class="status">Version 1.0 · Status: working paper, under review at <em>International Journal of Hospitality Management</em>.</p>
        <p class="canonical">Canonical page: <a href="/revemo">optimisationblindness.org/revemo</a></p>
        <p class="status">Suggested citation:</p>
        <p class="citation">Vasconcelos, R. (forthcoming). Revenue per Emotional Moment: A property-level measurement framework for emotional value in hospitality. <em>International Journal of Hospitality Management</em>.</p>
      </div>

      <div class="library-entry">
        <p class="name">DEQI — Destination Emotional Quality Index</p>
        <p class="description">Destination-level measurement framework tracking three observable signatures of AI-driven emotional erosion in tourism cities: emotional diversity (EDI), spatial convergence (SCR), and mediation ratio (MR).</p>
        <p class="status">Version 1.0 · Status: working paper, submitted to <em>International Journal of Tourism Cities</em>, pending preprint.</p>
        <p class="canonical">Canonical page: <a href="/deqi">optimisationblindness.org/deqi</a></p>
        <p class="status">Suggested citation:</p>
        <p class="citation">Vasconcelos, R. (forthcoming). Optimisation blindness at the destination level: How AI systems erode emotional place quality in tourism cities. <em>International Journal of Tourism Cities</em>.</p>
      </div>
    </section>

    <section class="library-section">
      <h2>Mechanisms</h2>
      <div class="library-entry">
        <p class="name">Destination-level Circuit Breakers</p>
        <p class="description">Governance constraint embedded in destination-scale decision-making, triggered when DEQI thresholds are breached. Borrowed from the logic of financial-system circuit breakers and adapted to the problem of aggregate emotional erosion across a tourism city. Full specification appears in the DEQI working paper.</p>
        <p class="status">Status: conceptual proposal, awaiting empirical and institutional design.</p>
      </div>
    </section>

    <section class="library-section">
      <h2>Essays</h2>
      {essays.map((essay) => (
        <div class="library-entry">
          <p class="name">
            <a href={`/essays/${essay.id}`}>{essay.data.title}</a> · {dateFmt(essay.data.date)}
          </p>
          {essay.data.description && <p class="description">{essay.data.description}</p>}
          <p class="canonical">Canonical page: optimisationblindness.org/essays/{essay.id}</p>
        </div>
      ))}
    </section>

    <section class="library-section">
      <h2>Working papers</h2>
      <p>Listed by status.</p>

      <div class="library-entry">
        <p class="name"><em>Under review</em></p>
        <p class="citation">Vasconcelos, R. <em>Revenue per Emotional Moment.</em> International Journal of Hospitality Management.</p>
      </div>

      <div class="library-entry">
        <p class="name"><em>Submitted, pending preprint</em></p>
        <p class="citation">Vasconcelos, R. <em>Optimisation blindness at the destination level: How AI systems erode emotional place quality in tourism cities.</em> International Journal of Tourism Cities.</p>
      </div>
    </section>

    <section class="library-section">
      <h2>Version history</h2>
      <div class="library-entry">
        <p class="description"><strong>19 May 2026</strong> — Site launched. Concept v1.0, RevEmo v1.0, DEQI v1.0, destination-level circuit breakers introduced, first essay published, Library established.</p>
      </div>
    </section>
  </article>
</BaseLayout>
